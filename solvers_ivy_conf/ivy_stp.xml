<ivy-module version="2.0"
    xmlns:e="http://ant.apache.org/ivy/extra"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="http://ant.apache.org/ivy/schemas/ivy.xsd">

    <info organisation="org.sosy_lab" module="javasmt-solver-stp">
      <license name="MIT License" url="https://github.com/stp/stp/blob/master/LICENSE"/>
        <description>
            STP solver and JavaSMT JNI wrapper.
        </description>
    </info>

    <configurations>
        <conf name="solver-stp" />
    </configurations>

    <publications defaultconf="solver-stp">

        <!-- JNI wrapper -->
        <artifact name="libjavasmtstp" conf="solver-stp" type="shared-object" ext="so"/>

        <!-- STP core -->
        <artifact name="libstp" conf="solver-stp" type="shared-object" ext="so"/>
        <artifact name="libstp" conf="solver-stp" type="shared-object" ext="so.2.3"/>

        <!-- Dependencies -->
        <artifact name="libabc-pic" conf="solver-stp" type="shared-object" ext="so"/>
        <artifact name="libminisat" conf="solver-stp" type="shared-object" ext="so.2"/>

    </publications>

    <dependencies/>

</ivy-module>