<?xml version="1.0" encoding="UTF-8" ?>

<project name="publish-solvers-stp" basedir="." xmlns:ivy="antlib:org.apache.ivy.ant">

    <import file="macros.xml"/>

    <!-- ========================= -->
    <!-- Package STP              -->
    <!-- ========================= -->
    <target name="package-stp" depends="">

        <!-- Require STP path -->
        <fail unless="stp.path">
            Please specify the path to the directory with all the prepared .so files.
            The directory must contain: libjavasmtstp.so, libstp.so, libstp.so.2.3,
            libabc-pic.so, libminisat.so.2.1.0 or libminisat.so.2.
        </fail>

        <!-- Require custom revision -->
        <fail unless="stp.customRev">
            Please specify a custom revision with:
            -Dstp.customRev=XXX
        </fail>

        <!-- Get git short hash -->
        <property name="stp.repo.url" value="https://github.com/stp/stp.git"/>
        <exec executable="sh" outputproperty="stp.revision" failonerror="true">
            <arg value="-c"/>
            <arg value="git ls-remote ${stp.repo.url} HEAD | cut -f1 | cut -c1-7"/>
        </exec>

        <!-- Version string -->
        <property name="stp.version" value="${stp.customRev}-g${stp.revision}"/>

        <echo message="Building STP in version '${stp.version}'"/>

        <!-- ========================================= -->
        <!-- Patch STP dependency to versioned minisat -->
        <!-- ========================================= -->

        <exec executable="patchelf" dir="${stp.path}" failonerror="true">
            <arg value="--replace-needed"/>
            <arg value="libminisat.so.2"/>
            <arg value="libminisat-${stp.version}.so.2"/>
            <arg value="libstp.so.2.3"/>
        </exec>

        <!-- Ensure solver loads libraries from same directory -->
        <exec executable="patchelf" dir="${stp.path}" failonerror="true">
            <arg value="--set-rpath"/>
            <arg value="$ORIGIN"/>
            <arg value="libstp.so.2.3"/>
        </exec>

        <!-- ========================================= -->
        <!-- Copy and rename libraries for Ivy         -->
        <!-- ========================================= -->

        <property name="stp.dist.dir" value="${ivy.solver.dist.dir}/stp"/>
        <mkdir dir="${stp.dist.dir}"/>

        <copy file="${stp.path}/libjavasmtstp.so"
              tofile="${stp.dist.dir}/libjavasmtstp-${stp.version}.so"/>

        <copy file="${stp.path}/libstp.so"
              tofile="${stp.dist.dir}/libstp-${stp.version}.so"/>

        <copy file="${stp.path}/libstp.so.2.3"
              tofile="${stp.dist.dir}/libstp-${stp.version}.so.2.3"/>

        <copy file="${stp.path}/libabc-pic.so"
              tofile="${stp.dist.dir}/libabc-pic-${stp.version}.so"/>

        <copy file="${stp.path}/libminisat.so.2.1.0"
              tofile="${stp.dist.dir}/libminisat-${stp.version}.so.2"/>

        <echo message="Prepared artifacts in ${stp.dist.dir}/"/>

    </target>

    <!-- ========================= -->
    <!-- Publish STP              -->
    <!-- ========================= -->

    <target name="publish-stp"
            depends="package-stp, load-ivy"
            description="Publish STP binaries to Ivy repository.">

        <ivy:resolve conf="solver-stp"
                     file="solvers_ivy_conf/ivy_stp.xml" />

        <publishToRepository
            solverName="STP"
            solverVersion="${stp.version}"
            distDir="${stp.dist.dir}"/>

    </target>

</project>